{
  "name": "internal-data-platform-iam-role-chaining-lab",
  "description": "Synthetic role chaining environment for internal data platform variants.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {"action_type": "enumerate", "target": "arn:aws:iam::123456789012:root", "parameters": {"service": "iam", "region": "us-east-1"}, "tool": "iam_list_roles"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/FinanceBrokerRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/FinanceBrokerRole", "session_name": "idp-broker"}, "tool": "iam_passrole"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "session_name": "idp-broker-decoy"}, "tool": "iam_passrole"}
        ]
      }
    }
  },
  "transitions": [
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:root", "observation": {"details": "Listed roles.", "discovered_roles": ["arn:aws:iam::123456789012:role/FinanceBrokerRole", "arn:aws:iam::123456789012:role/ReportsBrokerRole", "arn:aws:iam::123456789012:role/PayrollDataAccessRole"]}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/FinanceBrokerRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/FinanceBrokerRole", "details": "Assumed FinanceBrokerRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/FinanceBrokerRole": {
          "available_actions": [
            {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "session_name": "idp-dataaccess"}, "tool": "iam_passrole"}
          ]
        }
      }
    },
    {"action_type": "assume_role", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "observation": {"granted_role": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "details": "Assumed ReportsBrokerRole."}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:role/FinanceBrokerRole",
      "target": "arn:aws:iam::123456789012:role/PayrollDataAccessRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "details": "Assumed PayrollDataAccessRole."}
    }
  ]
}
