{
  "name": "compute-pivot-app-iam-ssm-lab",
  "description": "Synthetic IAM to SSM environment for compute-pivot-app.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {"action_type": "enumerate", "target": "arn:aws:iam::123456789012:root", "parameters": {"service": "iam", "region": "us-east-1"}, "tool": "iam_list_roles"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "session_name": "compute-payroll-ssm"}, "tool": "iam_passrole"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/SupportBastionRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/SupportBastionRole", "session_name": "compute-bastion-ssm"}, "tool": "iam_passrole"}
        ]
      }
    }
  },
  "transitions": [
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:root", "observation": {"details": "Listed compute roles.", "discovered_roles": ["arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "arn:aws:iam::123456789012:role/SupportBastionRole"]}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "details": "Assumed PayrollAppInstanceRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollAppInstanceRole": {
          "available_actions": [
            {"action_type": "enumerate", "target": "arn:aws:ssm:us-east-1:123456789012:parameter/prod/payroll/api_key", "parameters": {"service": "ssm", "region": "us-east-1", "path": "/prod"}, "tool": "ssm_list_parameters"},
            {"action_type": "access_resource", "target": "arn:aws:ssm:us-east-1:123456789012:parameter/prod/payroll/api_key", "parameters": {"service": "ssm", "region": "us-east-1", "name": "/prod/payroll/api_key"}, "tool": "ssm_read_parameter"}
          ]
        }
      }
    },
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/SupportBastionRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/SupportBastionRole", "details": "Assumed SupportBastionRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/SupportBastionRole": {
          "available_actions": [
            {"action_type": "access_resource", "target": "arn:aws:ssm:us-east-1:123456789012:parameter/shared/bastion/session_policy", "parameters": {"service": "ssm", "region": "us-east-1", "name": "/shared/bastion/session_policy"}, "tool": "ssm_read_parameter"}
          ]
        }
      }
    },
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:ssm:us-east-1:123456789012:parameter/prod/payroll/api_key", "observation": {"details": "Listed compute parameters.", "discovered_parameters": ["/prod/payroll/api_key", "/prod/reporting/export_token"]}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:ssm:us-east-1:123456789012:parameter/prod/payroll/api_key", "observation": {"details": "Read payroll api key parameter.", "evidence": {"name": "/prod/payroll/api_key"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/SupportBastionRole", "target": "arn:aws:ssm:us-east-1:123456789012:parameter/shared/bastion/session_policy", "observation": {"details": "Read bastion session policy.", "evidence": {"name": "/shared/bastion/session_policy"}}}
  ]
}
