      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "details": "Assumed PayrollAppInstanceRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollAppInstanceRole": {
          "available_actions": [
            {"action_type": "enumerate", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll/backend-db-password", "parameters": {"service": "secretsmanager", "region": "us-east-1", "name_prefix": "prod/"}, "tool": "secretsmanager_list_secrets"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll/backend-db-password", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/payroll/backend-db-password"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_a", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/sys/kv_a"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_b", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/sys/kv_b"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s1", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/app/s1"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s2", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/app/s2"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s3", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/app/s3"}, "tool": "secretsmanager_read_secret"}
          ]
        }
      }
    },
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/LegacyReportInstanceRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/LegacyReportInstanceRole", "details": "Assumed LegacyReportInstanceRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/LegacyReportInstanceRole": {
          "available_actions": [
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/reporting/export-token", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/reporting/export-token"}, "tool": "secretsmanager_read_secret"}
          ]
        }
      }
    },
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll/backend-db-password", "observation": {"details": "Listed compute secrets.", "discovered_secrets": ["prod/payroll/backend-db-password", "prod/reporting/export-token", "prod/sys/kv_a", "prod/sys/kv_b", "prod/app/s1", "prod/app/s2", "prod/app/s3"]}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll/backend-db-password", "observation": {"details": "Read payroll backend password.", "evidence": {"secret_id": "prod/payroll/backend-db-password"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_a", "observation": {"details": "Read obfuscated local secret kv_a.", "evidence": {"secret_id": "prod/sys/kv_a"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_b", "observation": {"details": "Read obfuscated local secret kv_b.", "evidence": {"secret_id": "prod/sys/kv_b"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s1", "observation": {"details": "Read obfuscated local secret s1.", "evidence": {"secret_id": "prod/app/s1"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s2", "observation": {"details": "Read obfuscated local secret s2.", "evidence": {"secret_id": "prod/app/s2"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s3", "observation": {"details": "Read obfuscated local secret s3.", "evidence": {"secret_id": "prod/app/s3"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/LegacyReportInstanceRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/reporting/export-token", "observation": {"details": "Read reporting export token.", "evidence": {"secret_id": "prod/reporting/export-token"}}}
  ]
