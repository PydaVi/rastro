{
  "name": "internal-data-platform-iam-secrets-lab",
  "description": "Synthetic IAM to Secrets environment for internal data platform variants.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {"action_type": "enumerate", "target": "arn:aws:iam::123456789012:root", "parameters": {"service": "iam", "region": "us-east-1"}, "tool": "iam_list_roles"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "session_name": "idp-secrets"}, "tool": "iam_passrole"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "session_name": "idp-secrets-decoy"}, "tool": "iam_passrole"}
        ]
      }
    }
  },
  "transitions": [
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:root", "observation": {"details": "Listed roles.", "discovered_roles": ["arn:aws:iam::123456789012:role/PayrollDataAccessRole", "arn:aws:iam::123456789012:role/ReportsBrokerRole"]}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollDataAccessRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "details": "Assumed PayrollDataAccessRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollDataAccessRole": {
          "available_actions": [
            {"action_type": "enumerate", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key", "parameters": {"service": "secretsmanager", "region": "us-east-1", "name_prefix": "prod/"}, "tool": "secretsmanager_list_secrets"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/payroll-api-key"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-archive-token", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/payroll-archive-token"}, "tool": "secretsmanager_read_secret"},
            {"action_type": "access_resource", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/finance-payroll-reporting-token", "parameters": {"service": "secretsmanager", "region": "us-east-1", "secret_id": "prod/finance-payroll-reporting-token"}, "tool": "secretsmanager_read_secret"}
          ]
        }
      }
    },
    {"action_type": "assume_role", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "observation": {"granted_role": "arn:aws:iam::123456789012:role/ReportsBrokerRole", "details": "Assumed ReportsBrokerRole."}},
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key", "observation": {"details": "Listed secrets.", "discovered_secrets": ["prod/payroll-api-key", "prod/payroll-archive-token", "prod/finance-payroll-reporting-token"]}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key", "observation": {"details": "Read payroll api key.", "evidence": {"secret_id": "prod/payroll-api-key"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-archive-token", "observation": {"details": "Read payroll archive token.", "evidence": {"secret_id": "prod/payroll-archive-token"}}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollDataAccessRole", "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/finance-payroll-reporting-token", "observation": {"details": "Read finance payroll reporting token.", "evidence": {"secret_id": "prod/finance-payroll-reporting-token"}}}
  ]
}
