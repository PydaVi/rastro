{
  "name": "serverless-business-app-iam-kms-data-lab",
  "description": "Synthetic IAM to KMS to data environment for serverless-business-app.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {"action_type": "enumerate", "target": "arn:aws:iam::123456789012:root", "parameters": {"service": "iam", "region": "us-east-1"}, "tool": "iam_list_roles"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/PayrollDecryptRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/PayrollDecryptRole", "session_name": "sba-decrypt"}, "tool": "iam_passrole"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/BillingWorkerRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/BillingWorkerRole", "session_name": "sba-billing"}, "tool": "iam_passrole"}
        ]
      }
    }
  },
  "transitions": [
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:root", "observation": {"details": "Listed roles.", "discovered_roles": ["arn:aws:iam::123456789012:role/PayrollDecryptRole", "arn:aws:iam::123456789012:role/BillingWorkerRole"]}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollDecryptRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollDecryptRole", "details": "Assumed PayrollDecryptRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollDecryptRole": {
          "available_actions": [
            {"action_type": "access_resource", "target": "arn:aws:kms:us-east-1:123456789012:key/payroll-runtime", "parameters": {"service": "kms", "region": "us-east-1", "key_id": "arn:aws:kms:us-east-1:123456789012:key/payroll-runtime"}, "tool": "kms_decrypt"}
          ]
        }
      }
    },
    {"action_type": "assume_role", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:role/BillingWorkerRole", "observation": {"granted_role": "arn:aws:iam::123456789012:role/BillingWorkerRole", "details": "Assumed BillingWorkerRole."}},
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollDecryptRole",
      "target": "arn:aws:kms:us-east-1:123456789012:key/payroll-runtime",
      "observation": {"details": "Decrypted payroll runtime material.", "evidence": {"key_id": "arn:aws:kms:us-east-1:123456789012:key/payroll-runtime"}}
    }
  ]
}
