{
  "name": "mixed-generalization-iam-s3-lab",
  "description": "Synthetic IAM to S3 environment for mixed-generalization benchmark.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {
            "action_type": "enumerate",
            "target": "arn:aws:iam::123456789012:root",
            "parameters": {"service": "iam", "region": "us-east-1"},
            "tool": "iam_list_roles"
          },
          {
            "action_type": "assume_role",
            "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
            "parameters": {
              "service": "sts",
              "region": "us-east-1",
              "role_arn": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
              "session_name": "mixed-payroll-s3"
            },
            "tool": "iam_passrole"
          },
          {
            "action_type": "assume_role",
            "target": "arn:aws:iam::123456789012:role/ServerlessAuditRole",
            "parameters": {
              "service": "sts",
              "region": "us-east-1",
              "role_arn": "arn:aws:iam::123456789012:role/ServerlessAuditRole",
              "session_name": "mixed-audit-s3"
            },
            "tool": "iam_passrole"
          }
        ]
      }
    }
  },
  "transitions": [
    {
      "action_type": "enumerate",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:root",
      "observation": {
        "details": "Listed mixed benchmark roles.",
        "discovered_roles": [
          "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
          "arn:aws:iam::123456789012:role/ServerlessAuditRole"
        ]
      }
    },
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
      "observation": {
        "granted_role": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
        "details": "Assumed PayrollAppInstanceRole."
      },
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollAppInstanceRole": {
          "available_actions": [
            {
              "action_type": "enumerate",
              "target": "arn:aws:s3:::mixed-payroll-data-prod",
              "parameters": {"service": "s3", "region": "us-east-1", "bucket": "mixed-payroll-data-prod"},
              "tool": "s3_list_bucket"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:s3:::mixed-payroll-data-prod/payroll/2026-03/payroll.csv",
              "parameters": {
                "service": "s3",
                "region": "us-east-1",
                "bucket": "mixed-payroll-data-prod",
                "object_key": "payroll/2026-03/payroll.csv"
              },
              "tool": "s3_read_sensitive"
            }
          ]
        }
      }
    },
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/ServerlessAuditRole",
      "observation": {
        "granted_role": "arn:aws:iam::123456789012:role/ServerlessAuditRole",
        "details": "Assumed ServerlessAuditRole."
      }
    },
    {
      "action_type": "enumerate",
      "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
      "target": "arn:aws:s3:::mixed-payroll-data-prod",
      "observation": {
        "details": "Listed mixed payroll bucket.",
        "discovered_objects": ["payroll/2026-03/payroll.csv"]
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole",
      "target": "arn:aws:s3:::mixed-payroll-data-prod/payroll/2026-03/payroll.csv",
      "observation": {
        "details": "Read mixed payroll dump.",
        "evidence": {
          "bucket": "mixed-payroll-data-prod",
          "object_key": "payroll/2026-03/payroll.csv"
        }
      }
    }
  ]
}
