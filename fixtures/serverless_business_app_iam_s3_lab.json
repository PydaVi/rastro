{
  "name": "serverless-business-app-iam-s3-lab",
  "description": "Synthetic IAM to S3 environment for serverless-business-app.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {"action_type": "enumerate", "target": "arn:aws:iam::123456789012:root", "parameters": {"service": "iam", "region": "us-east-1"}, "tool": "iam_list_roles"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/PayrollHandlerRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/PayrollHandlerRole", "session_name": "sba-payroll"}, "tool": "iam_passrole"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/ServerlessAuditRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/ServerlessAuditRole", "session_name": "sba-audit"}, "tool": "iam_passrole"}
        ]
      }
    }
  },
  "transitions": [
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:root", "observation": {"details": "Listed roles.", "discovered_roles": ["arn:aws:iam::123456789012:role/PayrollHandlerRole", "arn:aws:iam::123456789012:role/ServerlessAuditRole"]}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollHandlerRole", "details": "Assumed PayrollHandlerRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollHandlerRole": {
          "available_actions": [
            {"action_type": "enumerate", "target": "arn:aws:s3:::serverless-payroll-exports-prod", "parameters": {"service": "s3", "region": "us-east-1", "bucket": "serverless-payroll-exports-prod"}, "tool": "s3_list_bucket"},
            {"action_type": "access_resource", "target": "arn:aws:s3:::serverless-payroll-exports-prod/exports/payroll-2026-03.csv", "parameters": {"service": "s3", "region": "us-east-1", "bucket": "serverless-payroll-exports-prod", "object_key": "exports/payroll-2026-03.csv"}, "tool": "s3_read_sensitive"}
          ]
        }
      }
    },
    {"action_type": "assume_role", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:role/ServerlessAuditRole", "observation": {"granted_role": "arn:aws:iam::123456789012:role/ServerlessAuditRole", "details": "Assumed ServerlessAuditRole."}},
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole", "target": "arn:aws:s3:::serverless-payroll-exports-prod", "observation": {"details": "Listed exports bucket.", "discovered_objects": ["exports/payroll-2026-03.csv"]}},
    {"action_type": "access_resource", "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole", "target": "arn:aws:s3:::serverless-payroll-exports-prod/exports/payroll-2026-03.csv", "observation": {"details": "Read payroll export.", "evidence": {"bucket": "serverless-payroll-exports-prod", "object_key": "exports/payroll-2026-03.csv"}}}
  ]
}
