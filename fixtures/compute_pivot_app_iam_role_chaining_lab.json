{
  "name": "compute-pivot-app-iam-role-chaining-lab",
  "description": "Synthetic role chaining environment for compute-pivot-app.",
  "version": "0.1",
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {"action_type": "enumerate", "target": "arn:aws:iam::123456789012:root", "parameters": {"service": "iam", "region": "us-east-1"}, "tool": "iam_list_roles"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/SupportBastionRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/SupportBastionRole", "session_name": "compute-bastion-chain"}, "tool": "iam_passrole"},
          {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/ComputeAuditRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/ComputeAuditRole", "session_name": "compute-audit-chain"}, "tool": "iam_passrole"}
        ]
      }
    }
  },
  "transitions": [
    {"action_type": "enumerate", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:root", "observation": {"details": "Listed compute roles.", "discovered_roles": ["arn:aws:iam::123456789012:role/SupportBastionRole", "arn:aws:iam::123456789012:role/ComputeAuditRole", "arn:aws:iam::123456789012:role/PayrollAppInstanceRole"]}},
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/SupportBastionRole",
      "observation": {"granted_role": "arn:aws:iam::123456789012:role/SupportBastionRole", "details": "Assumed SupportBastionRole."},
      "update_identities": {
        "arn:aws:iam::123456789012:role/SupportBastionRole": {
          "available_actions": [
            {"action_type": "assume_role", "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "parameters": {"service": "sts", "region": "us-east-1", "role_arn": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "session_name": "compute-payroll-chain"}, "tool": "iam_passrole"}
          ]
        }
      }
    },
    {"action_type": "assume_role", "actor": "arn:aws:iam::123456789012:user/platform-analyst", "target": "arn:aws:iam::123456789012:role/ComputeAuditRole", "observation": {"granted_role": "arn:aws:iam::123456789012:role/ComputeAuditRole", "details": "Assumed ComputeAuditRole."}},
    {"action_type": "assume_role", "actor": "arn:aws:iam::123456789012:role/SupportBastionRole", "target": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "observation": {"granted_role": "arn:aws:iam::123456789012:role/PayrollAppInstanceRole", "details": "Assumed PayrollAppInstanceRole via bastion role."}}
  ]
}
