{
  "name": "serverless-business-app-iam-secrets-lab",
  "description": "Synthetic IAM to Secrets environment for serverless-business-app.",
  "version": "0.1",
  "aliases": {
    "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key": [
      "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/r/a1"
    ]
  },
  "state": {
    "flags": [],
    "identities": {
      "arn:aws:iam::123456789012:user/platform-analyst": {
        "available_actions": [
          {
            "action_type": "enumerate",
            "target": "arn:aws:iam::123456789012:root",
            "parameters": {
              "service": "iam",
              "region": "us-east-1"
            },
            "tool": "iam_list_roles"
          },
          {
            "action_type": "assume_role",
            "target": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
            "parameters": {
              "service": "sts",
              "region": "us-east-1",
              "role_arn": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
              "session_name": "sba-secrets"
            },
            "tool": "iam_passrole"
          },
          {
            "action_type": "assume_role",
            "target": "arn:aws:iam::123456789012:role/InternalAdminSyncRole",
            "parameters": {
              "service": "sts",
              "region": "us-east-1",
              "role_arn": "arn:aws:iam::123456789012:role/InternalAdminSyncRole",
              "session_name": "sba-admin"
            },
            "tool": "iam_passrole"
          }
        ]
      }
    }
  },
  "transitions": [
    {
      "action_type": "enumerate",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:root",
      "observation": {
        "details": "Listed roles.",
        "discovered_roles": [
          "arn:aws:iam::123456789012:role/PayrollHandlerRole",
          "arn:aws:iam::123456789012:role/InternalAdminSyncRole"
        ]
      }
    },
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "observation": {
        "granted_role": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
        "details": "Assumed PayrollHandlerRole."
      },
      "update_identities": {
        "arn:aws:iam::123456789012:role/PayrollHandlerRole": {
          "available_actions": [
            {
              "action_type": "enumerate",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "name_prefix": "prod/"
              },
              "tool": "secretsmanager_list_secrets"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "prod/payroll-api-key"
              },
              "tool": "secretsmanager_read_secret"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:internal/admin-token",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "internal/admin-token"
              },
              "tool": "secretsmanager_read_secret"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_a",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "prod/sys/kv_a"
              },
              "tool": "secretsmanager_read_secret"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_b",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "prod/sys/kv_b"
              },
              "tool": "secretsmanager_read_secret"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s1",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "prod/app/s1"
              },
              "tool": "secretsmanager_read_secret"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s2",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "prod/app/s2"
              },
              "tool": "secretsmanager_read_secret"
            },
            {
              "action_type": "access_resource",
              "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s3",
              "parameters": {
                "service": "secretsmanager",
                "region": "us-east-1",
                "secret_id": "prod/app/s3"
              },
              "tool": "secretsmanager_read_secret"
            }
          ]
        }
      }
    },
    {
      "action_type": "assume_role",
      "actor": "arn:aws:iam::123456789012:user/platform-analyst",
      "target": "arn:aws:iam::123456789012:role/InternalAdminSyncRole",
      "observation": {
        "granted_role": "arn:aws:iam::123456789012:role/InternalAdminSyncRole",
        "details": "Assumed InternalAdminSyncRole."
      }
    },
    {
      "action_type": "enumerate",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key",
      "observation": {
        "details": "Listed secrets.",
        "discovered_secrets": [
          "prod/payroll-api-key",
          "internal/admin-token"
        ]
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/payroll-api-key",
      "observation": {
        "details": "Read payroll api key.",
        "evidence": {
          "secret_id": "prod/payroll-api-key"
        }
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:internal/admin-token",
      "observation": {
        "details": "Read internal admin token.",
        "evidence": {
          "secret_id": "internal/admin-token"
        }
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_a",
      "observation": {
        "details": "Read obfuscated local secret kv_a.",
        "evidence": {
          "secret_id": "prod/sys/kv_a"
        }
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/sys/kv_b",
      "observation": {
        "details": "Read obfuscated local secret kv_b.",
        "evidence": {
          "secret_id": "prod/sys/kv_b"
        }
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s1",
      "observation": {
        "details": "Read obfuscated local secret s1.",
        "evidence": {
          "secret_id": "prod/app/s1"
        }
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s2",
      "observation": {
        "details": "Read obfuscated local secret s2.",
        "evidence": {
          "secret_id": "prod/app/s2"
        }
      }
    },
    {
      "action_type": "access_resource",
      "actor": "arn:aws:iam::123456789012:role/PayrollHandlerRole",
      "target": "arn:aws:secretsmanager:us-east-1:123456789012:secret:prod/app/s3",
      "observation": {
        "details": "Read obfuscated local secret s3.",
        "evidence": {
          "secret_id": "prod/app/s3"
        }
      }
    }
  ]
}
